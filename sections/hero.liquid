<section class="relative overflow-hidden">

  <!-- SLIDER WRAPPER -->
  <div id="heroSlider" class="relative w-full h-[500px]">

    <!-- SLIDES -->
    <div class="slide absolute inset-0 opacity-100 transition duration-700">
      <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-black/30 flex items-center justify-center text-center">
        <div class="text-white">
          <h1 class="text-4xl md:text-5xl font-bold">Upgrade Your Style</h1>
          <p class="mt-3">Premium quality products</p>
        </div>
      </div>
    </div>

    <div class="slide absolute inset-0 opacity-0 transition duration-700">
      <img src="https://images.unsplash.com/photo-1512496015851-a90fb38ba796" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-black/30 flex items-center justify-center text-center">
        <div class="text-white">
          <h1 class="text-4xl md:text-5xl font-bold">New Collection 2026</h1>
          <p class="mt-3">Discover latest trends</p>
        </div>
      </div>
    </div>

    <div class="slide absolute inset-0 opacity-0 transition duration-700">
      <img src="https://images.unsplash.com/photo-1491553895911-0055eca6402d" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-black/30 flex items-center justify-center text-center">
        <div class="text-white">
          <h1 class="text-4xl md:text-5xl font-bold">Limited Time Deals</h1>
          <p class="mt-3">Grab before it's gone</p>
        </div>
      </div>
    </div>

  </div>

  <!-- DOTS -->
  <div class="absolute bottom-5 left-1/2 transform -translate-x-1/2 flex space-x-2">
    <span class="dot w-3 h-3 bg-white rounded-full opacity-100"></span>
    <span class="dot w-3 h-3 bg-white rounded-full opacity-50"></span>
    <span class="dot w-3 h-3 bg-white rounded-full opacity-50"></span>
  </div>

</section>

<!-- SLIDER SCRIPT -->
<script>
  let slides = document.querySelectorAll('.slide');
  let dots = document.querySelectorAll('.dot');
  let index = 0;

  function showSlide(i) {
    slides.forEach((slide, idx) => {
      slide.style.opacity = idx === i ? '1' : '0';
    });

    dots.forEach((dot, idx) => {
      dot.style.opacity = idx === i ? '1' : '0.5';
    });
  }

  function nextSlide() {
    index = (index + 1) % slides.length;
    showSlide(index);
  }

  setInterval(nextSlide, 4000);
</script>
