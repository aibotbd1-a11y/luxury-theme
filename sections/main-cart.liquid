<div class="max-w-5xl mx-auto px-4 py-10">
  <h1 class="text-2xl font-bold mb-6">Your Cart</h1>

  {% if cart.item_count > 0 %}
    
    <ul>
      {% for item in cart.items %}
        <li class="flex justify-between items-center mb-4 border-b pb-4">
          
          <div>
            <h2 class="font-semibold">{{ item.product.title }}</h2>
            <p>{{ item.quantity }} × {{ item.price | money }}</p>
          </div>

          <p class="font-bold">{{ item.line_price | money }}</p>

        </li>
      {% endfor %}
    </ul>

    <div class="mt-6 text-right">
      <p class="text-xl font-bold">Total: {{ cart.total_price | money }}</p>

      <a href="/checkout" class="mt-4 inline-block bg-black text-white px-6 py-3 rounded-lg">
        Checkout
      </a>
    </div>

  {% else %}
    
    <p>Your cart is empty.</p>

  {% endif %}
</div>