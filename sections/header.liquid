<header class="bg-white border-b">

  <div class="flex items-center justify-between px-6 py-3 max-w-7xl mx-auto">
    
    <!-- LOGO -->
    <div class="text-2xl font-bold">
      <a href="/">Shoppy</a>
    </div>

    <!-- SEARCH -->
    <div class="flex-1 mx-6">
      <form action="/search" method="get" class="relative">
        <input 
          type="text" 
          name="q"
          placeholder="Search products..." 
          class="w-full border rounded-full px-5 py-2 focus:outline-none"
        >
        <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 bg-black text-white px-4 py-1 rounded-full">
          🔍
        </button>
      </form>
    </div>

    <!-- RIGHT -->
    <div class="flex items-center gap-4 text-sm">
      <a href="/account">👤 Account</a>
      <a href="/cart">🛒 Cart</a>
    </div>

  </div>

</header>
