<div class="max-w-5xl mx-auto px-4 py-10">
  <div class="grid md:grid-cols-2 gap-10">
    
    <!-- Product Image -->
    <div>
      <img src="{{ product.featured_image | image_url: width: 800 }}" 
           alt="{{ product.title }}" 
           class="w-full rounded-xl">
    </div>

    <!-- Product Info -->
    <div>
      <h1 class="text-2xl font-bold">{{ product.title }}</h1>
      
      <p class="text-xl mt-4">{{ product.price | money }}</p>
      <p class="text-sm text-green-600 mt-2">🔥 Only few items left</p>
      <p class="text-sm text-gray-500">🚚 Delivery: 5–8 days</p>
      <p class="text-sm text-yellow-500">⭐ 4.8 Rating</p>

      <form method="post" action="/cart/add" class="mt-6">
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        
        <button type="submit" class="bg-black text-white px-6 py-3 rounded-lg">
          Add to Cart
        </button>
      </form>

      <div class="mt-6 text-gray-600">
        {{ product.description }}
      </div>
    </div>

  </div>
</div>
