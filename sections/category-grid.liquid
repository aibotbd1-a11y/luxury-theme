<section class="category-section">
  <div class="page-width">

    <div class="category-wrapper">

      <!-- LEFT -->
      <div class="category-sidebar">
        <h3>Categories</h3>
        <ul>
          {% for block in section.blocks %}
            {% if block.settings.collection != blank %}
              <li>
                <a href="{{ block.settings.collection.url }}">
                  {{ block.settings.collection.title }} →
                </a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <!-- GRID -->
      <div class="category-grid">
        {% for block in section.blocks %}
          {% if block.settings.collection != blank %}
            <a href="{{ block.settings.collection.url }}" class="category-card">

              {% if block.settings.collection.featured_image %}
                <img src="{{ block.settings.collection.featured_image | image_url: width: 400 }}">
              {% endif %}

              <p>{{ block.settings.collection.title }}</p>

            </a>
          {% endif %}
        {% endfor %}
      </div>

      <!-- RIGHT -->
      <div class="category-offer">
        <h3>Super Deals</h3>
        <p>Special offers this month</p>
        <a href="/collections/all" class="btn">View more</a>
      </div>

    </div>

  </div>
</section>

<style>
.category-wrapper {
  display: grid;
  grid-template-columns: 1fr 2fr 1fr;
  gap: 20px;
}

.category-sidebar {
  background: #f5f5f5;
  padding: 20px;
  border-radius: 12px;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

.category-card {
  background: #f5f5f5;
  padding: 10px;
  border-radius: 12px;
  text-align: center;
  text-decoration: none;
  color: black;
}

.category-card img {
  width: 100%;
  border-radius: 10px;
}

.category-offer {
  background: #f3c99c;
  padding: 20px;
  border-radius: 12px;
  text-align: center;
}
</style>

{% schema %}
{
  "name": "Category Grid",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
