<section class="category-section">
  <div class="page-width">
    
    <div class="category-wrapper">
      
      <!-- LEFT SIDE LIST -->
      <div class="category-sidebar">
        <h3>Categories</h3>
        <ul>
          {% for collection in collections %}
            {% if collection.products_count > 0 %}
              <li>
                <a href="{{ collection.url }}">
                  {{ collection.title }} →
                </a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <!-- MIDDLE GRID -->
      <div class="category-grid">
        {% for collection in collections %}
          {% if collection.products_count > 0 %}
            <a href="{{ collection.url }}" class="category-card">
              
              {% if collection.featured_image %}
                <img 
                  src="{{ collection.featured_image | image_url: width: 400 }}" 
                  alt="{{ collection.title }}"
                >
              {% else %}
                <div class="no-image"></div>
              {% endif %}
              
              <p>{{ collection.title }}</p>
            </a>
          {% endif %}
        {% endfor %}
      </div>

      <!-- RIGHT SIDE BOX -->
      <div class="category-offer">
        <h3>Super Deals</h3>
        <p>Special offers this month</p>
        <a href="/collections/all" class="btn">View more</a>
      </div>

    </div>

  </div>
</section>

<style>
.category-wrapper {
  display: grid;
  grid-template-columns: 1fr 2fr 1fr;
  gap: 20px;
}

.category-sidebar {
  background: #f5f5f5;
  padding: 20px;
  border-radius: 12px;
}

.category-sidebar ul {
  list-style: none;
  padding: 0;
}

.category-sidebar li {
  margin-bottom: 10px;
}

.category-sidebar a {
  text-decoration: none;
  color: #000;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

.category-card {
  background: #f5f5f5;
  padding: 10px;
  border-radius: 12px;
  text-align: center;
  text-decoration: none;
  color: #000;
  transition: 0.3s;
}

.category-card:hover {
  transform: translateY(-5px);
}

.category-card img {
  width: 100%;
  border-radius: 10px;
}

.category-offer {
  background: #f3c99c;
  padding: 20px;
  border-radius: 12px;
  text-align: center;
}

.category-offer .btn {
  display: inline-block;
  background: black;
  color: white;
  padding: 10px 20px;
  border-radius: 25px;
  text-decoration: none;
  margin-top: 10px;
}
</style>
