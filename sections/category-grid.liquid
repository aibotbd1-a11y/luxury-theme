<section class="py-16 bg-brand-light">
  <div class="max-w-6xl mx-auto px-4">
    
    <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center">
      Shop by Category
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      
      {% for collection in collections %}
        <a href="{{ collection.url }}" class="group block">
          
          <div class="rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-lg transition">
            
            {% if collection.image %}
              <img 
                src="{{ collection.image | image_url: width: 500 }}" 
                class="w-full h-40 object-cover group-hover:scale-105 transition duration-500"
              >
            {% endif %}
            
            <div class="p-4 text-center">
              <h3 class="font-medium text-gray-900">
                {{ collection.title }}
              </h3>
            </div>

          </div>

        </a>
      {% endfor %}

    </div>

  </div>
</section>
