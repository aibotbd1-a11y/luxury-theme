{% doc %}
  @prompt
    Create a full-width Apple-style hero slider section with the following features:
    
    - Full-width slider with auto-play and manual dot navigation controls
    - Smooth fade transition between slides (not a sliding animation)
    - Dark gradient overlay on top of background images
    - Center-aligned text layout with:
      - Bold, large heading
      - Subheading text below the heading
      - Rounded CTA button with hover scale animation effect
    - Soft background glow effect using subtle gradients behind the content
    - Optional product highlight image that can be shown alongside the text
    - Each slide should be customizable with its own background image, heading, subheading, CTA button text and link, and optional product image
    - The section should have settings for: auto-play speed, overlay darkness, glow color, and number of slides
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 500px;
    overflow: hidden;
    display: block;
  }

  .ai-hero-slider__slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-hero-slider__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 1s ease-in-out;
    pointer-events: none;
  }

  .ai-hero-slider__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ai-hero-slider__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-slider__background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-slider__background-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-slider__background-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-hero-slider__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}), rgba(0, 0, 0, {{ block.settings.overlay_opacity | times: 0.8 }}));
    z-index: 2;
  }

  .ai-hero-slider__content-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    padding: 40px 20px;
  }

  .ai-hero-slider__content-{{ ai_gen_id }} {
    text-align: center;
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
  }

  .ai-hero-slider__text-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
  }

  .ai-hero-slider__glow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, {{ block.settings.glow_color }} 0%, transparent 70%);
    opacity: 0.4;
    z-index: 1;
    pointer-events: none;
  }

  .ai-hero-slider__heading-{{ ai_gen_id }} {
    font-size: 72px;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 20px;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .ai-hero-slider__subheading-{{ ai_gen_id }} {
    font-size: 28px;
    font-weight: 400;
    color: #f5f5f5;
    margin: 0 0 40px;
    line-height: 1.4;
    opacity: 0.9;
  }

  .ai-hero-slider__cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 40px;
    background-color: {{ block.settings.cta_background_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: 980px;
    font-size: 18px;
    font-weight: 600;
    transition: transform 0.3s ease, background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-slider__cta-{{ ai_gen_id }}:hover {
    transform: scale(1.05);
    background-color: {{ block.settings.cta_hover_background_color }};
  }

  .ai-hero-slider__product-image-{{ ai_gen_id }} {
    max-width: 500px;
    width: 100%;
    height: auto;
  }

  .ai-hero-slider__product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.3));
  }

  .ai-hero-slider__dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 4;
  }

  .ai-hero-slider__dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.4);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .ai-hero-slider__dot-{{ ai_gen_id }}.active {
    background-color: rgba(255, 255, 255, 1);
    width: 24px;
    border-radius: 4px;
  }

  .ai-hero-slider__dot-{{ ai_gen_id }}:hover {
    background-color: rgba(255, 255, 255, 0.7);
  }

  @media screen and (max-width: 768px) {
    .ai-hero-slider-{{ ai_gen_id }} {
      height: 100vh;
      min-height: 600px;
    }

    .ai-hero-slider__heading-{{ ai_gen_id }} {
      font-size: 42px;
    }

    .ai-hero-slider__subheading-{{ ai_gen_id }} {
      font-size: 20px;
      margin-bottom: 30px;
    }

    .ai-hero-slider__cta-{{ ai_gen_id }} {
      padding: 14px 32px;
      font-size: 16px;
    }

    .ai-hero-slider__product-image-{{ ai_gen_id }} {
      max-width: 300px;
    }

    .ai-hero-slider__glow-{{ ai_gen_id }} {
      width: 400px;
      height: 400px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-hero-slider__heading-{{ ai_gen_id }} {
      font-size: 32px;
    }

    .ai-hero-slider__subheading-{{ ai_gen_id }} {
      font-size: 18px;
    }
  }
{% endstyle %}

<apple-hero-slider-{{ ai_gen_id }}
  class="ai-hero-slider-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-slider__slides-{{ ai_gen_id }}">
    {% for i in (1..block.settings.number_of_slides) %}
      {% liquid
        assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
        assign slide_background_key = 'slide_' | append: i | append: '_background'
        assign slide_heading_key = 'slide_' | append: i | append: '_heading'
        assign slide_subheading_key = 'slide_' | append: i | append: '_subheading'
        assign slide_cta_text_key = 'slide_' | append: i | append: '_cta_text'
        assign slide_cta_link_key = 'slide_' | append: i | append: '_cta_link'
        assign slide_product_image_key = 'slide_' | append: i | append: '_product_image'

        assign slide_enabled = block.settings[slide_enabled_key]
        assign slide_background = block.settings[slide_background_key]
        assign slide_heading = block.settings[slide_heading_key]
        assign slide_subheading = block.settings[slide_subheading_key]
        assign slide_cta_text = block.settings[slide_cta_text_key]
        assign slide_cta_link = block.settings[slide_cta_link_key]
        assign slide_product_image = block.settings[slide_product_image_key]
      %}

      {% if slide_enabled %}
        <div
          class="ai-hero-slider__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
          data-slide-index="{{ forloop.index0 }}"
        >
          <div class="ai-hero-slider__background-{{ ai_gen_id }}">
            {% if slide_background %}
              <img
                src="{{ slide_background | image_url: width: 2400 }}"
                alt="{{ slide_background.alt | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="{{ slide_background.width }}"
                height="{{ slide_background.height }}"
              >
            {% else %}
              <div class="ai-hero-slider__background-placeholder-{{ ai_gen_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-hero-slider__overlay-{{ ai_gen_id }}"></div>

          <div class="ai-hero-slider__content-wrapper-{{ ai_gen_id }}">
            <div class="ai-hero-slider__content-{{ ai_gen_id }}">
              <div class="ai-hero-slider__text-content-{{ ai_gen_id }}">
                <div class="ai-hero-slider__glow-{{ ai_gen_id }}"></div>

                {% if slide_heading != blank %}
                  <h2 class="ai-hero-slider__heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
                {% endif %}

                {% if slide_subheading != blank %}
                  <p class="ai-hero-slider__subheading-{{ ai_gen_id }}">{{ slide_subheading }}</p>
                {% endif %}

                {% if slide_cta_text != blank %}
                  <a
                    href="{{ slide_cta_link | default: '#' }}"
                    class="ai-hero-slider__cta-{{ ai_gen_id }}"
                  >
                    {{ slide_cta_text }}
                  </a>
                {% endif %}
              </div>

              {% if slide_product_image %}
                <div class="ai-hero-slider__product-image-{{ ai_gen_id }}">
                  <img
                    src="{{ slide_product_image | image_url: width: 1000 }}"
                    alt="{{ slide_product_image.alt | escape }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    width="{{ slide_product_image.width }}"
                    height="{{ slide_product_image.height }}"
                  >
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ai-hero-slider__dots-{{ ai_gen_id }}">
    {% for i in (1..block.settings.number_of_slides) %}
      {% liquid
        assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
        assign slide_enabled = block.settings[slide_enabled_key]
      %}
      {% if slide_enabled %}
        <button
          class="ai-hero-slider__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
          data-slide-index="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
        ></button>
      {% endif %}
    {% endfor %}
  </div>
</apple-hero-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class AppleHeroSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-hero-slider__slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-hero-slider__dot-{{ ai_gen_id }}');
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;

        this.setupEventListeners();

        if (this.autoplay && this.slides.length > 1) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        this.dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const slideIndex = parseInt(dot.dataset.slideIndex);
            this.goToSlide(slideIndex);
            if (this.autoplay) {
              this.resetAutoplay();
            }
          });
        });
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        this.dots[this.currentSlide].classList.remove('active');

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        this.dots[this.currentSlide].classList.add('active');
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      resetAutoplay() {
        clearInterval(this.autoplayInterval);
        this.startAutoplay();
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('apple-hero-slider-{{ ai_gen_id }}', AppleHeroSlider{{ ai_gen_id }});
  })();
</script>

