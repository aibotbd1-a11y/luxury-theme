{% doc %}
  @prompt
    Create a modern e-commerce navigation bar inspired by Amazon, AliExpress, and Apple UI.
    
    ---
    
    ## 🧱 Layout Structure
    
    * Full-width horizontal navigation bar
    * Clean, centered layout
    * Two main sections:
    
    1. LEFT: "Shop By Categories" button
    2. RIGHT: Navigation menu links
    
    ---
    
    ## 🟦 LEFT SECTION (CATEGORY BUTTON)
    
    ### Content:
    
    * Button text: "Shop By Categories"
    * Icon: hamburger menu (3 lines)
    
    ### Design:
    
    * Background: primary color (blue or brand color)
    * Text: white
    * Shape: pill / rounded (full radius)
    * Padding: medium-large
    
    ### Interaction:
    
    * Hover:
    
      * slight darken
      * subtle scale (1.03)
    * Click:
    
      * opens mega category dropdown
    
    ---
    
    ## 📂 CATEGORY DROPDOWN (MEGA MENU)
    
    ### Behavior:
    
    * Opens on click or hover
    
    ### Layout:
    
    * Multi-column dropdown (3–5 columns)
    
    ### Content:
    
    * Category groups
    * Subcategories under each group
    
    Example:
    
    * Electronics
    
      * Mobile
      * Laptop
      * Accessories
    
    * Fashion
    
      * Men
      * Women
      * Kids
    
    ### Design:
    
    * White background
    * Rounded corners
    * Soft shadow
    * Large padding
    * Clean grid layout
    
    ---
    
    ## 📌 RIGHT SECTION (NAV LINKS)
    
    ### Menu Items:
    
    * Home
    * Shop
    * Categories (with SALE badge)
    * Products (with HOT badge)
    * Top deals
    * Elements
    
    ---
    
    ## 🏷️ BADGES (IMPORTANT)
    
    * SALE badge:
    
      * Color: green
      * Small rounded tag
    * HOT badge:
    
      * Color: pink/red
    
    ### Style:
    
    * Small font
    * Rounded corners
    * Positioned beside menu text
    
    ---
    
    ## 🎨 UI STYLE (APPLE + AMAZON MIX)
    
    * Minimal but functional
    * Clean typography
    * Balanced spacing
    * Subtle separators
    
    Font:
    
    * Inter / SF Pro
    
    ---
    
    ## ✨ HOVER EFFECTS
    
    * Menu items:
    
      * underline animation OR color change
    * Dropdown:
    
      * smooth fade + slide down
    
    ---
    
    ## 🎞️ ANIMATION
    
    * Dropdown:
    
      * fade + translateY
    * Button hover:
    
      * smooth transition (300ms)
    
    ---
    
    ## 📱 RESPONSIVE DESIGN
    
    * Tablet:
    
      * compress spacing
    * Mobile:
    
      * hamburger full menu
      * collapsible categories
    
    ---
    
    ## ⚙️ TECH REQUIREMENTS
    
    * Shopify Liquid compatible
    * Tailwind CSS
    * JS for dropdown toggle
    
    ---
    
    ## 🎯 FINAL GOAL
    
    Menu should:
    
    * Look like real eCommerce navigation
    * Be clean like Apple
    * Be powerful like Amazon
    * Improve navigation UX
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-nav-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.nav_bg_color }};
    border-bottom: 1px solid {{ block.settings.border_color }};
    position: relative;
    z-index: 1000;
  }

  .ai-nav-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.nav_padding }}px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
  }

  .ai-nav-left-{{ ai_gen_id }} {
    flex-shrink: 0;
  }

  .ai-category-btn-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 24px;
    background-color: {{ block.settings.category_btn_bg }};
    color: {{ block.settings.category_btn_text_color }};
    border: none;
    border-radius: 50px;
    font-size: {{ block.settings.category_btn_font_size }}px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .ai-category-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.category_btn_hover_bg }};
    transform: scale(1.03);
  }

  .ai-hamburger-icon-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 3px;
    width: 18px;
  }

  .ai-hamburger-icon-{{ ai_gen_id }} span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: currentColor;
    border-radius: 2px;
  }

  .ai-nav-right-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    justify-content: flex-end;
  }

  .ai-nav-menu-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.menu_gap }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-nav-item-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-nav-link-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    color: {{ block.settings.menu_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.menu_font_size }}px;
    font-weight: 500;
    transition: color 0.3s ease;
    position: relative;
  }

  .ai-nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.menu_hover_color }};
  }

  .ai-nav-link-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 12px;
    right: 12px;
    height: 2px;
    background-color: {{ block.settings.menu_hover_color }};
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }

  .ai-nav-link-{{ ai_gen_id }}:hover::after {
    transform: scaleX(1);
  }

  .ai-badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 2px 8px;
    font-size: 10px;
    font-weight: 600;
    border-radius: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-badge-sale-{{ ai_gen_id }} {
    background-color: {{ block.settings.sale_badge_bg }};
    color: {{ block.settings.sale_badge_text_color }};
  }

  .ai-badge-hot-{{ ai_gen_id }} {
    background-color: {{ block.settings.hot_badge_bg }};
    color: {{ block.settings.hot_badge_text_color }};
  }

  .ai-mega-menu-{{ ai_gen_id }} {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: {{ block.settings.dropdown_bg }};
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
    border-radius: {{ block.settings.dropdown_radius }}px;
    margin-top: 10px;
    padding: {{ block.settings.dropdown_padding }}px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    pointer-events: none;
  }

  .ai-mega-menu-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .ai-mega-menu-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.dropdown_columns }}, 1fr);
    gap: 30px;
  }

  .ai-category-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-category-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.category_title_color }};
    margin: 0 0 8px 0;
    padding-bottom: 8px;
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-subcategory-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-subcategory-link-{{ ai_gen_id }} {
    color: {{ block.settings.subcategory_color }};
    text-decoration: none;
    font-size: {{ block.settings.subcategory_size }}px;
    transition: color 0.3s ease, padding-left 0.3s ease;
    display: block;
  }

  .ai-subcategory-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.subcategory_hover_color }};
    padding-left: 8px;
  }

  .ai-mobile-toggle-{{ ai_gen_id }} {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.menu_text_color }};
  }

  .ai-mobile-toggle-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  @media screen and (max-width: 990px) {
    .ai-nav-container-{{ ai_gen_id }} {
      gap: 15px;
    }

    .ai-nav-menu-{{ ai_gen_id }} {
      gap: 15px;
    }

    .ai-category-btn-{{ ai_gen_id }} {
      padding: 10px 18px;
      font-size: 14px;
    }

    .ai-nav-link-{{ ai_gen_id }} {
      font-size: 14px;
      padding: 6px 8px;
    }

    .ai-mega-menu-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-mobile-toggle-{{ ai_gen_id }} {
      display: block;
    }

    .ai-nav-right-{{ ai_gen_id }} {
      position: fixed;
      top: 0;
      right: -100%;
      width: 80%;
      max-width: 320px;
      height: 100vh;
      background-color: {{ block.settings.nav_bg_color }};
      box-shadow: -5px 0 20px rgba(0, 0, 0, 0.1);
      transition: right 0.3s ease;
      z-index: 1001;
      overflow-y: auto;
      padding: 20px;
    }

    .ai-nav-right-{{ ai_gen_id }}.active {
      right: 0;
    }

    .ai-nav-menu-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      width: 100%;
    }

    .ai-nav-item-{{ ai_gen_id }} {
      width: 100%;
      border-bottom: 1px solid {{ block.settings.border_color }};
    }

    .ai-nav-link-{{ ai_gen_id }} {
      width: 100%;
      padding: 15px 0;
    }

    .ai-nav-link-{{ ai_gen_id }}::after {
      display: none;
    }

    .ai-mega-menu-{{ ai_gen_id }} {
      position: static;
      width: 100%;
      margin-top: 0;
      padding: 15px 0;
      box-shadow: none;
      border-radius: 0;
    }

    .ai-mega-menu-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 15px;
    }

    .ai-category-btn-{{ ai_gen_id }} {
      width: 100%;
      justify-content: center;
    }
  }

  .ai-overlay-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 999;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-overlay-{{ ai_gen_id }}.active {
    display: block;
    opacity: 1;
  }
{% endstyle %}

<nav-bar-{{ ai_gen_id }} class="ai-nav-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-nav-container-{{ ai_gen_id }}">
    <div class="ai-nav-left-{{ ai_gen_id }}">
      <button class="ai-category-btn-{{ ai_gen_id }}" data-category-toggle>
        <span class="ai-hamburger-icon-{{ ai_gen_id }}">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span>{{ block.settings.category_button_text }}</span>
      </button>
    </div>

    <div class="ai-nav-right-{{ ai_gen_id }}">
      <ul class="ai-nav-menu-{{ ai_gen_id }}">
        {% if block.settings.show_home %}
          <li class="ai-nav-item-{{ ai_gen_id }}">
            <a href="{{ block.settings.home_link }}" class="ai-nav-link-{{ ai_gen_id }}">
              {{ block.settings.home_text }}
            </a>
          </li>
        {% endif %}

        {% if block.settings.show_shop %}
          <li class="ai-nav-item-{{ ai_gen_id }}">
            <a href="{{ block.settings.shop_link }}" class="ai-nav-link-{{ ai_gen_id }}">
              {{ block.settings.shop_text }}
            </a>
          </li>
        {% endif %}

        {% if block.settings.show_categories %}
          <li class="ai-nav-item-{{ ai_gen_id }}">
            <a href="{{ block.settings.categories_link }}" class="ai-nav-link-{{ ai_gen_id }}">
              {{ block.settings.categories_text }}
              {% if block.settings.show_sale_badge %}
                <span class="ai-badge-{{ ai_gen_id }} ai-badge-sale-{{ ai_gen_id }}">{{ block.settings.sale_text }}</span>
              {% endif %}
            </a>
          </li>
        {% endif %}

        {% if block.settings.show_products %}
