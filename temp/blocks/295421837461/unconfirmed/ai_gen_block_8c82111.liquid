<script>
  (function() {
    class NavBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.categoryBtn = this.querySelector('[data-category-toggle]');
        this.megaMenu = this.querySelector('[data-mega-menu]');
        this.mobileToggle = this.querySelector('[data-mobile-toggle]');
        this.navRight = this.querySelector('.ai-nav-right-{{ ai_gen_id }}');
        this.overlay = this.querySelector('[data-overlay]');

        this.setupEventListeners();
      }

      setupEventListeners() {
        if (this.categoryBtn && this.megaMenu) {
          this.categoryBtn.addEventListener('click', () => {
            this.toggleMegaMenu();
          });

          document.addEventListener('click', (e) => {
            if (!this.categoryBtn.contains(e.target) && !this.megaMenu.contains(e.target)) {
              this.closeMegaMenu();
            }
          });
        }

        if (this.mobileToggle && this.navRight) {
          this.mobileToggle.addEventListener('click', () => {
            this.toggleMobileMenu();
          });
        }

        if (this.overlay) {
          this.overlay.addEventListener('click', () => {
            this.closeMobileMenu();
          });
        }
      }

      toggleMegaMenu() {
        this.megaMenu.classList.toggle('active');
      }

      closeMegaMenu() {
        this.megaMenu.classList.remove('active');
      }

      toggleMobileMenu() {
        this.navRight.classList.toggle('active');
        this.overlay.classList.toggle('active');
        document.body.style.overflow = this.navRight.classList.contains('active') ? 'hidden' : '';
      }

      closeMobileMenu() {
        this.navRight.classList.remove('active');
        this.overlay.classList.remove('active');
        document.body.style.overflow = '';
      }
    }

    customElements.define('nav-bar-{{ ai_gen_id }}', NavBar{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "E-commerce navigation",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
