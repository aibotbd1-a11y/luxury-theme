{% doc %}
  @prompt
    A heading with an animated glowing effect
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-glow-heading-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-glow-heading__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    color: {{ block.settings.text_color }};
    margin: 0;
    position: relative;
    display: inline-block;
    text-shadow: 
      0 0 {{ block.settings.glow_intensity }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_intensity | times: 2 }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_intensity | times: 3 }}px {{ block.settings.glow_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-glow-heading__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.7);
    }
  }
{% endstyle %}

<glow-heading-{{ ai_gen_id }} class="ai-glow-heading-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading_text != blank %}
    <h2 class="ai-glow-heading__text-{{ ai_gen_id }}">
      {{ block.settings.heading_text }}
    </h2>
  {% else %}
    <h2 class="ai-glow-heading__text-{{ ai_gen_id }}">
      Add your heading text
    </h2>
  {% endif %}
</glow-heading-{{ ai_gen_id }}>

<script>
  (function() {
    class GlowHeading{{ai_gen_id}} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.heading = this.querySelector('.ai-glow-heading__text-{{ ai_gen_id }}');
        if (!this.heading) return;

        const glowIntensity = {{ block.settings.glow_intensity }};
        const glowColor = '{{ block.settings.glow_color }}';
        const pulseSpeed = {{ block.settings.pulse_speed }};

        let intensity = glowIntensity;
        let increasing = true;

        const animate = () => {
          if (increasing) {
            intensity += 0.5;
            if (intensity >= glowIntensity * 1.5) {
              increasing = false;
            }
          } else {
            intensity -= 0.5;
            if (intensity <= glowIntensity * 0.5) {
              increasing = true;
            }
          }

          this.heading.style.textShadow = `
            0 0 ${intensity}px ${glowColor},
            0 0 ${intensity * 2}px ${glowColor},
            0 0 ${intensity * 3}px ${glowColor}
          `;

          setTimeout(() => {
            requestAnimationFrame(animate);
          }, pulseSpeed);
        };

        animate();
      }
    }

    customElements.define('glow-heading-{{ ai_gen_id }}', GlowHeading{{ai_gen_id}});
  })();
</script>

{% schema %}
{
  "name": "Glow heading",
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Glowing Heading"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Glow effect"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#00d4ff"
    },
    {
      "type": "range",
      "id": "glow_intensity",
      "label": "Glow intensity",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "pulse_speed",
      "label": "Pulse speed",
      "min": 10,
      "max": 100,
      "step": 10,
      "unit": "ms",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Glow heading"
    }
  ]
}
{% endschema %}
