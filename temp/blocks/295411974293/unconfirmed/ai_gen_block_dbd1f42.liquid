{% doc %}
  @prompt
    Create a modern premium e-commerce hero section with a multi-banner grid layout inspired by Apple, Amazon, and high-end Shopify stores.
    
    LAYOUT STRUCTURE:
    - Responsive CSS grid: Left large banner (2/3 width) + Right column (1/3 width) with 3 smaller banners
    - Right column: 1 wide banner on top + 2 small banners side-by-side on bottom
    - All cards: rounded corners (16-20px), no harsh borders, soft shadows
    - Clean premium spacing throughout
    
    BANNER 1 - MAIN LEFT (large featured):
    - Full height left panel with soft gradient or light neutral background
    - Small label badge at top (e.g. "BUY 1 GET 1 FREE") - customizable
    - Bold large heading (e.g. "Multivitamin Healthy Life") - customizable
    - Subtext line (e.g. "Isotonix Multivitamins") - customizable
    - CTA button "Get yours Today" - rounded, customizable link
    - Product image floating with realistic drop shadow
    - Apple-style clean spacing
    
    BANNER 2 - TOP RIGHT (promo wide):
    - Soft purple gradient background (customizable colors)
    - Label: "Up to 45% OFF" - customizable
    - Heading: "Get Healthy With Exclusive Medical Product Deals!" - customizable
    - CTA button: "View More" - customizable link
    - Text left-aligned, product image right side
    - Same rounded card style
    
    BANNER 3 - BOTTOM LEFT SMALL:
    - Soft green pastel background (customizable)
    - Discount badge: "15% OFF" - customizable
    - Title: "Women's Health Gummies" - customizable
    - Product image centered
    - Compact layout with clean typography
    
    BANNER 4 - BOTTOM RIGHT SMALL:
    - Soft blue/gray gradient background (customizable)
    - Text: "Get 15% OFF" heading + "Premium Wellness Products" subtext - customizable
    - Product image right-aligned
    - Compact layout
    
    UI STYLE:
    - Inter / system-ui font stack
    - Minimal, clean, no harsh borders
    - Soft box shadows (increase on hover)
    - Rounded XL card radius (16-20px)
    - Pastel gradient color palette
    - Premium balanced typography hierarchy
    
    HOVER EFFECTS:
    - Product image: scale(1.05) zoom on hover
    - Card: soft shadow increase on hover
    - CTA button: slight scale + color shift
    - All transitions: 300ms ease
    
    RESPONSIVE:
    - Desktop: 2/3 + 1/3 grid layout as described
    - Tablet: 2-column equal grid
    - Mobile: all 4 banners stacked vertically, full width, maintain spacing and readability
    
    SHOPIFY SETTINGS (customizable per banner):
    - Background color / gradient start + end colors
    - Label/badge text
    - Heading text
    - Subheading/subtext
    - CTA button text and link URL
    - Product image upload
    - Show/hide each banner independently
    - Section padding and gap settings
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-hero-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-hero-grid__banner-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
  }

  .ai-hero-grid__banner-{{ ai_gen_id }}:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-hero-grid__banner-1-{{ ai_gen_id }} {
    grid-row: 1 / 3;
    background: linear-gradient(135deg, {{ block.settings.banner_1_bg_start }}, {{ block.settings.banner_1_bg_end }});
    min-height: 500px;
  }

  .ai-hero-grid__right-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-hero-grid__banner-2-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.banner_2_bg_start }}, {{ block.settings.banner_2_bg_end }});
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 30px;
  }

  .ai-hero-grid__bottom-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-hero-grid__banner-3-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.banner_3_bg_start }}, {{ block.settings.banner_3_bg_end }});
    min-height: 240px;
    padding: 30px;
  }

  .ai-hero-grid__banner-4-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.banner_4_bg_start }}, {{ block.settings.banner_4_bg_end }});
    min-height: 240px;
    padding: 30px;
  }

  .ai-hero-grid__badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 8px 16px;
    background-color: rgba(0, 0, 0, 0.08);
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-grid__heading-{{ ai_gen_id }} {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 12px 0;
    color: {{ block.settings.text_color }};
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  }

  .ai-hero-grid__subtext-{{ ai_gen_id }} {
    font-size: 18px;
    line-height: 1.5;
    margin: 0 0 24px 0;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
  }

  .ai-hero-grid__cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-weight: 600;
    font-size: 16px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-hero-grid__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_color }};
    transform: scale(1.02);
  }

  .ai-hero-grid__image-wrapper-{{ ai_gen_id }} {
    position: absolute;
    right: 40px;
    bottom: 0;
    width: 300px;
    height: 300px;
    transition: transform 0.3s ease;
  }

  .ai-hero-grid__banner-{{ ai_gen_id }}:hover .ai-hero-grid__image-wrapper-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-hero-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.15));
  }

  .ai-hero-grid__banner-2-content-{{ ai_gen_id }} {
    flex: 1;
    max-width: 60%;
  }

  .ai-hero-grid__banner-2-image-{{ ai_gen_id }} {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .ai-hero-grid__banner-{{ ai_gen_id }}:hover .ai-hero-grid__banner-2-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-hero-grid__banner-2-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 5px 15px rgba(0, 0, 0, 0.1));
  }

  .ai-hero-grid__heading-small-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 8px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-grid__heading-medium-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 8px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-grid__subtext-small-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.5;
    margin: 0 0 16px 0;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  .ai-hero-grid__banner-3-content-{{ ai_gen_id }},
  .ai-hero-grid__banner-4-content-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-hero-grid__small-image-{{ ai_gen_id }} {
    width: 100px;
    height: 100px;
    margin: 0 auto 16px;
    transition: transform 0.3s ease;
  }

  .ai-hero-grid__banner-{{ ai_gen_id }}:hover .ai-hero-grid__small-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-hero-grid__small-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 5px 15px rgba(0, 0, 0, 0.1));
  }

  .ai-hero-grid__banner-4-layout-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    text-align: left;
  }

  .ai-hero-grid__banner-4-text-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-hero-grid__banner-4-image-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .ai-hero-grid__banner-{{ ai_gen_id }}:hover .ai-hero-grid__banner-4-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-hero-grid__banner-4-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 5px 15px rgba(0, 0, 0, 0.1));
  }

  @media screen and (max-width: 989px) {
    .ai-hero-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
    }

    .ai-hero-grid__banner-1-{{ ai_gen_id }} {
      grid-row: auto;
      grid-column: 1 / -1;
    }

    .ai-hero-grid__right-column-{{ ai_gen_id }} {
      grid-column: 1 / -1;
    }

    .ai-hero-grid__heading-{{ ai_gen_id }} {
      font-size: 36px;
    }

    .ai-hero-grid__image-wrapper-{{ ai_gen_id }} {
      width: 250px;
      height: 250px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-hero-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-hero-grid__banner-{{ ai_gen_id }} {
      padding: 30px;
    }

    .ai-hero-grid__banner-1-{{ ai_gen_id }} {
      min-height: 400px;
    }

    .ai-hero-grid__banner-2-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: center;
      padding: 30px;
    }

    .ai-hero-grid__banner-2-content-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-hero-grid__banner-2-image-{{ ai_gen_id }} {
      margin-top: 20px;
    }

    .ai-hero-grid__bottom-row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-hero-grid__heading-{{ ai_gen_id }} {
      font-size: 32px;
    }

    .ai-hero-grid__image-wrapper-{{ ai_gen_id }} {
      width: 200px;
      height: 200px;
      right: 20px;
    }

    .ai-hero-grid__heading-small-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ai-hero-grid__heading-medium-{{ ai_gen_id }} {
      font-size: 18px;
    }
  }
{% endstyle %}

<premium-hero-grid-{{ ai_gen_id }} class="ai-hero-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-grid__container-{{ ai_gen_id }}">
    {% if block.settings.show_banner_1 %}
      <div class="ai-hero-grid__banner-{{ ai_gen_id }} ai-hero-grid__banner-1-{{ ai_gen_id }}">
        <div>
          {% if block.settings.banner_1_badge != blank %}
            <span class="ai-hero-grid__badge-{{ ai_gen_id }}">{{ block.settings.banner_1_badge }}</span>
          {% endif %}
          {% if block.settings.banner_1_heading != blank %}
            <h2 class="ai-hero-grid__heading-{{ ai_gen_id }}">{{ block.settings.banner_1_heading }}</h2>
          {% endif %}
          {% if block.settings.banner_1_subtext != blank %}
            <p class="ai-hero-grid__subtext-{{ ai_gen_id }}">{{ block.settings.banner_1_subtext }}</p>
          {% endif %}
          {% if block.settings.banner_1_cta_text != blank %}
            <a href="{{ block.settings.banner_1_cta_link }}" class="ai-hero-grid__cta-{{ ai_gen_id }}">
              {{ block.settings.banner_1_cta_text }}
            </a>
          {% endif %}
        </div>
        {% if block.settings.banner_1_image %}
          <div class="ai-hero-grid__image-wrapper-{{ ai_gen_id }}">
            <img
              src="{{ block.settings.banner_1_image | image_url: width: 600 }}"
              alt="{{ block.settings.banner_1_image.alt | escape }}"
              class="ai-hero-grid__image-{{ ai_gen_id }}"
              loading="lazy"
              width="300"
              height="300"
            >
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-hero-grid__right-column-{{ ai_gen_id }}">
      {% if block.settings.show_banner_2 %}
        <div class="ai-hero-grid__banner-{{ ai_gen_id }} ai-hero-grid__banner-2-{{ ai_gen_id }}">
          <div class="ai-hero-grid__banner-2-content-{{ ai_gen_id }}">
            {% if block.settings.banner_2_badge != blank %}
              <span class="ai-hero-grid__badge-{{ ai_gen_id }}">{{ block.settings.banner_2_badge }}</span>
            {% endif %}
            {% if block.settings.banner_2_heading != blank %}
              <h3 class="ai-hero-grid__heading-medium-{{ ai_gen_id }}">{{ block.settings.banner_2_heading }}</h3>
            {% endif %}
            {% if block.settings.banner_2_cta_text != blank %}
              <a href="{{ block.settings.banner_2_cta_link }}" class="ai-hero-grid__cta-{{ ai_gen_id }}">
                {{ block.settings.banner_2_cta_text }}
              </a>
            {% endif %}
          </div>
          {% if block.settings.banner_2_image %}
            <div class="ai-hero-grid__banner-2-image-{{ ai_gen_id }}">
              <img
                src="{{ block.settings.banner_2_image | image_url: width: 240 }}"
                alt="{{ block.settings.banner_2_image.alt | escape }}"
                loading="lazy"
                width="120"
                height="120"
              >
            </div>
          {% endif %}
        </div>
      {% endif %}

      <div class="ai-hero-grid__bottom-row-{{ ai_gen_id }}">
        {% if block.settings.show_banner_3 %}
          <div class="ai-hero-grid__banner-{{ ai_gen_id }} ai-hero-grid__banner-3-{{ ai_gen_id }}">
            <div class="ai-hero-grid__banner-3-content-{{ ai_gen_id }}">
              {% if block.settings.banner_3_badge != blank %}
                <span class="ai-hero-grid__badge-{{ ai_gen_id }}">{{ block.settings.banner_3_badge }}</span>
              {% endif %}
              {% if block.settings.banner_3_image %}
                <div class="ai-hero-grid__small-image-{{ ai_gen_id }}">
                  <img
                    src="{{ block.settings.banner_3_image | image_url: width: 200 }}"
                    alt="{{ block.settings.banner_3_image.alt | escape }}"
                    loading="lazy"
                    width="100"
                    height="100"
                  >
                </div>
              {% endif %}
              {% if block.settings.banner_3_heading != blank %}
                <h3 class="ai-hero-grid__heading-small-{{ ai_gen_id }}">{{ block.settings.banner_3_heading }}</h3>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_banner_4 %}
          <div class="ai-hero-grid__banner-{{ ai_gen_id }} ai-hero-grid__banner-4-{{ ai_gen_id }}">
            <div class="ai-hero-grid__banner-4-layout-{{ ai_gen_id }}">
              <div class="ai-hero-grid__banner-4-text-{{ ai_gen_id }}">
                {% if block.settings.banner_4_heading != blank %}
                  <h3 class="ai-hero-grid__heading-small-{{ ai_gen_id }}">{{ block.settings.banner_4_heading }}</h3>
                {% endif %}
                {% if block.settings.banner_4_subtext != blank %}
                  <p class="ai-hero-grid__subtext-small-{{ ai_gen_id }}">{{ block.settings.banner_4_subtext }}</p>
                {% endif %}
              </div>
              {% if block.settings.banner_4_image %}
                <div class="ai-hero-grid__banner-4-image-{{ ai_gen_id }}">
                  <img
                    src="{{ block.settings.banner_4_image | image_url: width: 160 }}"
                    alt="{{ block.settings.banner_4_image.alt | escape }}"
                    loading="lazy"
                    width="80"
                    height="80"
                  >
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</premium-hero-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class PremiumHeroGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('premium-hero-grid-{{ ai_gen_id }}', PremiumHeroGrid{{ ai_gen_id }});
  })();
</script>

