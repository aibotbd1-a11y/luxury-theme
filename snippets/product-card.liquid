<div class="group relative flex flex-col bg-white dark:bg-gray-900 rounded-[24px] overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 transform hover:-translate-y-1">
  
  <div class="relative aspect-[4/5] overflow-hidden bg-gray-100 dark:bg-gray-800">
    <div class="absolute top-4 left-4 z-10 flex flex-col gap-2">
      {% if product.compare_at_price > product.price %}
        <span class="bg-brand-accent text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide shadow-md">
          Sale
        </span>
      {% endif %}
      {% if product.metafields.custom.eco_friendly %}
        <span class="bg-green-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-md">🌱 Eco</span>
      {% endif %}
    </div>

    <div class="absolute top-4 right-4 z-10 flex flex-col gap-2 opacity-0 group-hover:opacity-100 transform translate-x-4 group-hover:translate-x-0 transition-all duration-300">
      <button class="bg-white/90 backdrop-blur p-2 rounded-full shadow-lg hover:text-brand-accent js-wishlist-btn" data-product-handle="{{ product.handle }}">❤️</button>
      <button class="bg-white/90 backdrop-blur p-2 rounded-full shadow-lg hover:text-brand-accent js-quick-view" data-product-url="{{ product.url }}">👁️</button>
    </div>

    <a href="{{ product.url | within: collection }}" class="block w-full h-full">
      <img src="{{ product.featured_image | image_url: width: 600, format: 'webp' }}" 
           loading="lazy" 
           alt="{{ product.title | escape }}" 
           class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
      {% if product.images[1] %}
        <img src="{{ product.images[1] | image_url: width: 600, format: 'webp' }}" 
             loading="lazy" 
             alt="{{ product.title | escape }}" 
             class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity duration-500">
      {% endif %}
    </a>
  </div>

  <div class="p-5 flex flex-col gap-2">
    <div class="flex justify-between items-start">
      <h3 class="text-sm font-semibold font-sans truncate pr-4 text-gray-900 dark:text-white">
        <a href="{{ product.url }}">{{ product.title }}</a>
      </h3>
      <div class="flex items-center text-xs text-yellow-400">
        ★ 4.8 </div>
    </div>
    
    <div class="flex items-center gap-2">
      <span class="font-bold text-lg text-brand-dark dark:text-white">{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        <span class="text-sm text-gray-400 line-through">{{ product.compare_at_price | money }}</span>
      {% endif %}
    </div>

    <form method="post" action="/cart/add" class="mt-2 relative overflow-hidden rounded-xl">
      <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
      <button type="submit" class="w-full bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-white font-medium py-3 rounded-xl group-hover:bg-brand-dark group-hover:text-white dark:group-hover:bg-brand-accent transition-colors duration-300 js-add-to-cart relative overflow-hidden">
        <span class="relative z-10">Buy Now</span>
        <p class="text-xs text-gray-500">🔥 23 people viewing</p>
        <div class="absolute inset-0 -translate-x-full bg-white/20 skew-x-12 group-hover:animate-[shine_1.5s_ease-in-out]"></div>
      </button>
    </form>
  </div>
</div>
